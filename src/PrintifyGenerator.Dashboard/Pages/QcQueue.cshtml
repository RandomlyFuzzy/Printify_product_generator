@page
@model QcQueueModel
@{
    ViewData["Title"] = "QC Queue";
    var snapshot = Model.Snapshot;
    var summary = snapshot.Summary;
}

<main class="dashboard-shell page-shell" data-qc-page>
    <section class="hero-panel qc-hero-panel">
        <div>
            <p class="eyebrow">QC Queue</p>
            <h1>Simple pass or block decisions for generated images.</h1>
            <p class="hero-copy">
                This queue keeps the review step compact: image, current state, QC pass or fail, and the buttons to allow it to continue or block it from continuing.
            </p>
        </div>
        <div class="hero-meta">
            <div>
                <span class="meta-label">Current filter</span>
                <strong>@Model.Status</strong>
            </div>
            <div>
                <span class="meta-label">Images shown</span>
                <strong id="qc-visible-count">@snapshot.Images.Count</strong>
            </div>
            <div>
                <span class="meta-label">Minimum publish score</span>
                <strong>@snapshot.Settings.MinimumPublishScore.ToString("0.0")</strong>
            </div>
        </div>
    </section>

    <section id="qc-flash-banner" class="flash-banner" hidden="@string.IsNullOrWhiteSpace(Model.FlashMessage)">@Model.FlashMessage</section>

    <section class="panel compact-panel">
        <div class="split-heading panel-heading tight-heading">
            <div>
                <p class="eyebrow">Filters</p>
                <h2>Current image states</h2>
            </div>
            <span class="muted">@summary.TotalImages total images discovered in the checking folder.</span>
        </div>
        <div class="filter-pills">
            <a asp-page="/QcQueue" asp-route-status="all" class="filter-pill @(Model.Status == "all" ? "is-active" : null)">All</a>
            <a asp-page="/QcQueue" asp-route-status="pending" class="filter-pill @(Model.Status == "pending" ? "is-active" : null)">Pending</a>
            <a asp-page="/QcQueue" asp-route-status="ready" class="filter-pill @(Model.Status == "ready" ? "is-active" : null)">Ready</a>
            <a asp-page="/QcQueue" asp-route-status="drafted" class="filter-pill @(Model.Status == "drafted" ? "is-active" : null)">Drafted</a>
            <a asp-page="/QcQueue" asp-route-status="blocked" class="filter-pill @(Model.Status == "blocked" ? "is-active" : null)">Blocked</a>
        </div>
    </section>

    <section class="panel review-panel">
        <div class="panel-heading split-heading">
            <div>
                <p class="eyebrow">Queue</p>
                <h2>QC pass or fail list</h2>
            </div>
            <span class="muted">Allow only overrides the score threshold. Safety flags still block continuation.</span>
        </div>

        <p id="qc-empty-state" class="muted" hidden="@(snapshot.Images.Count != 0)">No images matched the current filter.</p>

        <div id="qc-list" class="qc-list" hidden="@(snapshot.Images.Count == 0)">
            @foreach (var item in snapshot.Images)
            {
                var qcLabel = QcQueueModel.GetQcLabel(item);
                var qcCssClass = QcQueueModel.GetQcCssClass(item);

                    <article class="qc-row" data-qc-row data-image-path="@item.ImagePath">
                        <div class="qc-thumb-wrap">
                            <div class="image-frame qc-frame">
                                <img src="@item.ImageUrl" alt="Generated artwork @item.JobId" loading="lazy" />
                            </div>
                        </div>

                        <div class="qc-summary">
                            <div class="qc-heading">
                                <div>
                                    <h3>@item.JobId</h3>
                                    <p class="path-label">@item.RelativeDirectory</p>
                                    <a asp-page="/GeneratedImages" asp-route-status="@Model.Status" asp-route-focusImagePath="@item.ImagePath" class="filter-pill qc-details-link">View details</a>
                                </div>
                                <div class="qc-chip-row">
                                    <span class="state-pill @item.StatusCssClass" data-status-pill>@item.StatusLabel</span>
                                    <span class="qc-pill @qcCssClass" data-qc-pill>@qcLabel</span>
                                </div>
                            </div>

                            <div class="qc-meta-grid">
                                <div>
                                    <span>QC reason</span>
                                    <strong data-eligibility-reason>@item.EligibilityReason</strong>
                                </div>
                                <div>
                                    <span>Score</span>
                                    <strong>@(item.ReviewScore is float reviewScore ? reviewScore.ToString("0.0") : "-")</strong>
                                </div>
                                <div>
                                    <span>Override</span>
                                    <strong data-override-label>@item.PublishOverrideLabel</strong>
                                </div>
                                <div>
                                    <span>Drafts</span>
                                    <strong>@item.DraftCount</strong>
                                </div>
                            </div>
                        </div>

                        <div class="qc-actions">
                            <form method="post" asp-page-handler="SetOverride" class="qc-action-form" data-override-form>
                                <input type="hidden" name="imagePath" value="@item.ImagePath" />
                                <input type="hidden" name="status" value="@Model.Status" />

                                <div class="qc-button-stack">
                                    <button type="submit" name="mode" value="force-allow" class="primary-button @(item.PublishOverrideMode == PublishingOverrideModes.ForceAllow ? "button-selected" : null)" disabled="@(!item.CanForceAllow)">Allow to Continue</button>
                                    <button type="submit" name="mode" value="force-block" class="danger-button @(item.PublishOverrideMode == PublishingOverrideModes.ForceBlock ? "button-selected" : null)">Block Continuing</button>
                                    <button type="submit" name="mode" value="automatic" class="ghost-button @(item.PublishOverrideMode == PublishingOverrideModes.Automatic ? "button-selected" : null)">Automatic</button>
                                </div>
                            </form>

                            <p class="muted override-note" data-override-note>@QcQueueModel.GetOverrideNote(item)</p>
                            <p class="muted override-note" data-allow-note hidden="@item.CanForceAllow">Allow is unavailable until safety checks pass and a suitability file exists.</p>
                        </div>
                    </article>
            }
        </div>
    </section>
</main>

@section Scripts {
    <script>
        (() => {
            const page = document.querySelector("[data-qc-page]");
            if (!page) {
                return;
            }

            const flashBanner = document.getElementById("qc-flash-banner");
            const visibleCount = document.getElementById("qc-visible-count");
            const list = document.getElementById("qc-list");
            const emptyState = document.getElementById("qc-empty-state");

            const setFlash = (message, isError) => {
                if (!flashBanner) {
                    return;
                }

                flashBanner.textContent = message || "";
                flashBanner.hidden = !message;
                flashBanner.classList.toggle("flash-banner-error", Boolean(isError));
            };

            const updateListState = (count) => {
                if (visibleCount) {
                    visibleCount.textContent = String(count);
                }

                const hasRows = Boolean(list?.querySelector("[data-qc-row]"));
                if (list) {
                    list.hidden = !hasRows;
                }

                if (emptyState) {
                    emptyState.hidden = hasRows;
                }
            };

            const setBusy = (form, isBusy) => {
                form.querySelectorAll("button").forEach((button) => {
                    if (isBusy) {
                        button.dataset.wasDisabled = button.disabled ? "true" : "false";
                        button.disabled = true;
                        return;
                    }

                    button.disabled = button.dataset.wasDisabled === "true";
                    delete button.dataset.wasDisabled;
                });
            };

            const updateRow = (row, item) => {
                const statusPill = row.querySelector("[data-status-pill]");
                const qcPill = row.querySelector("[data-qc-pill]");
                const eligibilityReason = row.querySelector("[data-eligibility-reason]");
                const overrideLabel = row.querySelector("[data-override-label]");
                const overrideNote = row.querySelector("[data-override-note]");
                const allowNote = row.querySelector("[data-allow-note]");

                if (statusPill) {
                    statusPill.textContent = item.statusLabel;
                    statusPill.className = `state-pill ${item.statusCssClass}`;
                }

                if (qcPill) {
                    qcPill.textContent = item.qcLabel;
                    qcPill.className = `qc-pill ${item.qcCssClass}`;
                }

                if (eligibilityReason) {
                    eligibilityReason.textContent = item.eligibilityReason;
                }

                if (overrideLabel) {
                    overrideLabel.textContent = item.publishOverrideLabel;
                }

                if (overrideNote) {
                    overrideNote.textContent = item.overrideNote;
                }

                if (allowNote) {
                    allowNote.hidden = item.canForceAllow;
                }

                row.querySelectorAll("button[name='mode']").forEach((button) => {
                    button.classList.toggle("button-selected", button.value === item.publishOverrideMode);
                    if (button.value === "force-allow") {
                        button.disabled = !item.canForceAllow;
                    }
                });
            };

            document.querySelectorAll("[data-override-form]").forEach((form) => {
                form.addEventListener("submit", async (event) => {
                    event.preventDefault();

                    const submitter = event.submitter;
                    if (!(submitter instanceof HTMLButtonElement)) {
                        return;
                    }

                    const row = form.closest("[data-qc-row]");
                    const formData = new FormData(form);
                    let payload = null;
                    formData.set(submitter.name, submitter.value);

                    setBusy(form, true);

                    try {
                        const response = await fetch(form.action, {
                            method: "POST",
                            headers: {
                                "Accept": "application/json",
                                "X-Requested-With": "fetch"
                            },
                            body: formData
                        });

                        const payload = await response.json();
                        setFlash(payload.flashMessage, !payload.success);

                        if (!payload.success) {
                            return;
                        }

                        if (!payload.item || payload.item.matchesCurrentFilter === false) {
                            row?.remove();
                            updateListState(payload.visibleCount ?? 0);
                            return;
                        }

                        if (row) {
                            updateRow(row, payload.item);
                        }

                        updateListState(payload.visibleCount ?? 0);
                    } catch (error) {
                        console.error("Failed to save QC override.", error);
                        setFlash("Failed to save QC override. Refresh the page and try again.", true);
                    } finally {
                        setBusy(form, false);
                    }
                });
            });
        })();
    </script>
}